# ============================================================
# gharfund – Frontend Environment Variables Template
# ============================================================
# Copy this file to .env and fill in real values for local dev.
# NEVER commit .env or any file containing real secrets.
#
# Vite only exposes variables prefixed with VITE_ to the browser
# bundle.  Do NOT add server-side secrets here.
# ============================================================

# ------------------------------------------------------------
# Firebase (Phone OTP Auth)
# All six variables are required.  If any are missing the app
# will show "Firebase is not configured" and list exactly which
# names are absent in the browser console.
#
# Find these values in:
#   Firebase Console → Project Settings → General →
#   Your apps → Web app → SDK setup and configuration
# ------------------------------------------------------------
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ------------------------------------------------------------
# Supabase (Database / Row-Level Security)
# Find these values in:
#   Supabase Dashboard → Project → Settings → API
# ------------------------------------------------------------
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ------------------------------------------------------------
# App
# ------------------------------------------------------------
# Public base URL of the deployed app (no trailing slash)
# Example: https://gharfund.vercel.app
VITE_APP_BASE_URL=

# Founder WhatsApp number for support links (international format)
# Example: +9779800000000
VITE_FOUNDER_WHATSAPP=

# ------------------------------------------------------------
# Analytics (PostHog) – optional
# ------------------------------------------------------------
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://app.posthog.com
